@model ParkingManagement.Models.Admin
@{
    ViewBag.Title = "Super Admin Settings";
    Layout = "_SuperAdminLayout";
}

<style>
    .settings-card {
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        border: 1px solid #e2e8f0;
        padding: 30px;
        transition: all 0.3s ease;
    }

    .settings-header-icon {
        width: 55px;
        height: 55px;
        background: rgba(78, 115, 223, 0.1);
        color: #4e73df;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.88rem;
        color: #475569;
        margin-bottom: 6px;
    }

    .form-control {
        padding: 12px 16px;
        border-radius: 10px;
        border: 1.5px solid #cbd5e1;
        background-color: #f8fafc;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }

    .form-control:focus {
        border-color: #4e73df;
        box-shadow: 0 0 0 4px rgba(78, 115, 223, 0.15);
        background-color: #ffffff;
    }

    .btn-save {
        padding: 12px 28px;
        font-weight: 700;
        border-radius: 10px;
        background: linear-gradient(135deg, #4e73df 0%, #2e59d9 100%);
        color: #ffffff;
        border: none;
        box-shadow: 0 4px 14px rgba(78, 115, 223, 0.3);
        transition: all 0.3s ease;
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 18px rgba(78, 115, 223, 0.4);
        color: #ffffff;
    }

    .badge-role {
        background: rgba(78, 115, 223, 0.12);
        color: #2e59d9;
        font-weight: 600;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.8rem;
    }
</style>

<div class="container-fluid">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h3 class="fw-bold text-dark m-0">Account Settings</h3>
            <p class="text-muted small m-0">Manage your Super Admin profile details and password security.</p>
        </div>
        <span class="badge-role">
            <i class="fa-solid fa-shield-halved me-1"></i> Super Admin Account
        </span>
    </div>

    @if (TempData["SettingsSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4 rounded-3" role="alert">
            <i class="fa-solid fa-circle-check me-2 fs-5"></i> @TempData["SettingsSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["SettingsError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4 rounded-3" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2 fs-5"></i> @TempData["SettingsError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Left Side: Profile Summary -->
        <div class="col-lg-4">
            <div class="settings-card text-center h-100">
                <div class="mb-3 position-relative d-inline-block">
                    <img src="https://static.vecteezy.com/system/resources/previews/000/439/863/original/vector-users-icon.jpg" class="rounded-circle shadow" style="width: 110px; height: 110px; object-fit: cover; border: 4px solid #4e73df;" alt="Avatar">
                    <span class="position-absolute bottom-0 end-0 bg-success border border-2 border-white rounded-circle p-2" title="Active Account"></span>
                </div>
                <h5 class="fw-bold text-dark mb-1">@(Model?.name ?? "Super Admin")</h5>
                <p class="text-muted small mb-3">@(Model?.email ?? "superadmin@gmail.com")</p>
                <div class="p-3 bg-light rounded-3 text-start mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Role:</span>
                        <span class="fw-bold small text-dark">Super Administrator</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted small">System Access:</span>
                        <span class="badge bg-success bg-opacity-10 text-success small px-2 py-1">Full Control</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side: Edit Form -->
        <div class="col-lg-8">
            <div class="settings-card">
                <div class="d-flex align-items-center mb-4">
                    <div class="settings-header-icon me-3">
                        <i class="fa-solid fa-user-gear"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold text-dark m-0">Profile & Password</h4>
                        <small class="text-muted">Update your display name and change password</small>
                    </div>
                </div>

                <form method="post" asp-action="UpdateSettings">
                    <div class="mb-4">
                        <label class="form-label">Full Name</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-user text-muted"></i></span>
                            <input type="text" name="name" class="form-control border-start-0" value="@Model?.name" placeholder="Enter full name" required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Email Address (Read Only)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-envelope text-muted"></i></span>
                            <input type="email" class="form-control border-start-0 bg-light" value="@Model?.email" readonly />
                        </div>
                    </div>

                    <hr class="my-4 text-secondary opacity-25" />

                    <h5 class="fw-bold text-dark mb-3">
                        <i class="fa-solid fa-lock me-2 text-warning"></i> Change Password
                    </h5>
                    <p class="text-muted small mb-3">Leave password fields blank if you only wish to update your name.</p>

                    <div class="mb-3">
                        <label class="form-label">Current Password</label>
                        <input type="password" name="oldpass" class="form-control pass-field" placeholder="Enter current password to verify" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">New Password</label>
                            <input type="password" name="newpass" class="form-control pass-field" placeholder="Enter new password" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Confirm New Password</label>
                            <input type="password" name="confirmpass" class="form-control pass-field" placeholder="Repeat new password" />
                        </div>
                    </div>

                    <div class="form-check mb-4">
                        <input type="checkbox" class="form-check-input me-2" id="showPasswordToggle">
                        <label class="form-check-label small text-muted" for="showPasswordToggle">Show Passwords</label>
                    </div>

                    <div class="text-end">
                        <button type="submit" class="btn btn-save">
                            <i class="fa-solid fa-floppy-disk me-2"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('showPasswordToggle').addEventListener('change', function () {
        const passFields = document.querySelectorAll('.pass-field');
        passFields.forEach(field => {
            field.type = this.checked ? 'text' : 'password';
        });
    });
</script>
